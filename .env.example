# Ed25519 private key for the demo signer (base64, 32 raw bytes).
# Unset in dev = a fresh key is generated per server instance.
# In production (Vercel) set this so /keys.json is stable across instances.
# Generate one:  node -e "const ed=require('@noble/ed25519');console.log(Buffer.from(ed.utils.randomPrivateKey()).toString('base64'))"
BASIS_DEMO_SK=
